# ── 川渝云图 V1.0 环境变量 ──────────────────────────────────────────────────

# Supabase 数据库（必填：线索系统、项目云同步、用户认证）
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
# POSTGRES_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# Better Auth 认证（必填）
# BETTER_AUTH_SECRET=your-random-secret-at-least-32-chars

# 应用 URL（部署时必填）
# NEXT_PUBLIC_APP_URL=https://your-domain.com

# 高德地图 API（地址解析行政区划代码）
# AMAP_API_KEY=your_amap_web_api_key

# 阿里云短信（V2.0 正式版对接）
# ALIYUN_SMS_ACCESS_KEY_ID=your_access_key_id
# ALIYUN_SMS_ACCESS_KEY_SECRET=your_access_key_secret
# ALIYUN_SMS_SIGN_NAME=川渝云图
# ALIYUN_SMS_TEMPLATE_CODE=SMS_xxxxx

# 邮件服务（可选）
# RESEND_API_KEY=your_resend_api_key

# Google OAuth（可选，保留兼容）
# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret

# 跳过环境变量验证（构建时使用）
# SKIP_ENV_VALIDATION=true

# Dev server port (default: 3002)
# PORT=3002
